{
  "name": "@adaptive-ai/sdk",
  "version": "0.1.26",
  "private": false,
  "type": "module",
  "exports": {
    "./client": {
      "types": "./dist/client/index.d.ts",
      "import": "./dist/client/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build:dev": "pnpm run build && ./distribute-local.sh",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint --cache .",
    "lint:fix": "eslint --cache --fix .",
    "check": "NODE_OPTIONS='--max-old-space-size=8192' tsc --noEmit",
    "bundle": "./bundle.sh",
    "build": "tsup",
    "clean": "rimraf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build && pnpm run bundle"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "@trpc/client": ">=10",
    "@trpc/server": ">=10",
    "typed-rpc": ">=5",
    "lodash": ">=4",
    "nanoid": ">=4",
    "openai": ">=4",
    "react": ">=18",
    "superjson": ">=1",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-query": {
      "optional": true
    },
    "lodash": {
      "optional": true
    },
    "react": {
      "optional": false
    }
  },
  "optionalPeerDependencies": {
    "ws": "^8"
  },
  "devDependencies": {
    "@ac1/core": "workspace:*",
    "@ac1/iso": "workspace:*",
    "@types/eslint": "^8.44.2",
    "@types/lodash": "^4.14.200",
    "@types/node": "^20.14.8",
    "@types/object-inspect": "^1.13.0",
    "@types/react": "19.0.10",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "browser-image-compression": "^2.0.2",
    "dom-to-image-more": "^3.7.2",
    "eslint": "^8.47.0",
    "eslint-config-next": "15.5.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-formatter-codeframe": "^7.32.1",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.0",
    "npm-run-all": "^4.1.5",
    "object-inspect": "^1.13.4",
    "prettier": "^3.7.4",
    "rimraf": "^6.0.1",
    "tsup": "^8.2.4",
    "tsx": "^4.7.1",
    "typescript": "^5.8.2"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
